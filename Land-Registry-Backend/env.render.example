PORT=10000
SPRING_DATA_MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/land_registry_db?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-strong-random-secret
CORS_ALLOWED_ORIGINS=https://land-registry-frontend-jfbt.onrender.com
FABRIC_ENABLED=false

# Enable these only after Fabric is hosted separately and reachable from Render.
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=landregistry
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=peer-host:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_CERTIFICATE_PATH=/etc/secrets/fabric-cert.pem
FABRIC_PRIVATE_KEY_PATH=/etc/secrets/fabric-key.pem
FABRIC_TLS_CERT_PATH=/etc/secrets/fabric-tls-ca.pem
